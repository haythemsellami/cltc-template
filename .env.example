# Copy to .env and fill in. The market-making bot reads this (repo root); the optional Foundry deploy
# script reads PRIVATE_KEY / CASH / ASSET / RPC_URL. Never commit .env — it holds your private key.

# ── your identity ────────────────────────────────────────────────────────────────────────────────
# Funded Monad-testnet key that owns + operates your venue. If left blank, the bot generates one (in
# the file named by KEY_FILE) and prints the address for you to fund.
PRIVATE_KEY=
# KEY_FILE=.venue-key   # where a generated key is stored/reused (gitignored); only used when PRIVATE_KEY is blank

# ── network ──────────────────────────────────────────────────────────────────────────────────────
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# ── organizer endpoints (the organizer gives you these) ──────────────────────────────────────────
# OPERATOR_API_URL is the BASE origin — the bot appends /api/manifest itself, so do NOT include /api.
# On event day these are the organizer's public URLs, e.g.
#   OPERATOR_API_URL=https://<organizer-host>.ts.net
#   FEED_WS_URL=wss://<organizer-host>.ts.net/stream
# The defaults below match a local dry-run (the organizer's `setup.sh --local`).
OPERATOR_API_URL=http://localhost:8080
FEED_WS_URL=ws://localhost:7777/stream
# A bare KIND (aggTrade / bookTicker) follows the live round's market automatically — no symbol to
# configure. Set a full <symbol>@<kind> only to pin one stream (older feed servers).
FEED_PRICE_STREAM=aggTrade

# ── your venue ───────────────────────────────────────────────────────────────────────────────────
TEAM_NAME=my-team       # fallback venue label only — your roster name is set when you register on the dashboard
# The maker dashboard URL — where you register your team (with this bot's wallet).
DASHBOARD_URL=http://localhost:5176
# Reuse a venue you already deployed (skip deploy + fund, just register + quote). Leave blank to deploy fresh.
VENUE=

# ── quoting behaviour (tune freely; your pricing logic lives in market-making/src/strategy.ts) ────
TTL_SECONDS=30          # quote validity window: validUntil = now + this
REQUOTE_SECS=15         # refresh at least this often — keep this WELL BELOW TTL_SECONDS or quotes expire mid-gap
REQUOTE_BPS=15          # also re-quote immediately on a feed move this large
MON_FOR_GAS=0.5         # MON the funding gate waits for before proceeding
FALLBACK_PRICE=65000    # seed price (CASH per ASSET) if the feed hasn't ticked yet

# ── only for the optional Foundry deploy (contracts/script/DeployVenue.s.sol) ────────────────────
# CASH=0x...            # the active round's CASH token (from the operator dashboard / GET /api/manifest)
# ASSET=0x...           # the active round's ASSET token
